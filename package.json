{
  "name": "email-mcp",
  "version": "0.1.0",
  "description": "MCP Server for IMAP/SMTP email access (GMX, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["mcp", "email", "imap", "smtp", "gmx"],
  "author": "Secretary Project",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "imapflow": "^1.0.188",
    "nodemailer": "^8.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
